# ==============================
# Reject 分流规则
# ==============================


# ── 盗版/未知来源程序 ─────────

# 未知来源软件相关域名，可能为盗版程序广告模块
DOMAIN-SUFFIX, no-mad-world.club
DOMAIN-SUFFIX, club


# ── 广告平台（通用）────────────

# 合法 AI 广告平台，帮助品牌自动化寻找创作者做赞助内容，常被广告拦截工具列入 blocklist
DOMAIN-SUFFIX, agentio.com

# 实时竞价广告平台（RTB），美数科技旗下
DOMAIN-SUFFIX, 1rtb.net

# UBiX 移动广告聚合平台（UBiMAX SDK），接入多家广告源并进行用户行为追踪、广告效果归因
DOMAIN-SUFFIX, ubixioe.com

# 多用于成人直播、色情广告平台，有追踪行为和加载风险脚本的可能
DOMAIN-SUFFIX, mg-cdn.com


# ── 成人网站 ──────────────────

# 免费直播摄像头成人网站，大量加载第三方追踪器、广告网络，有恶意软件或指纹追踪风险
DOMAIN-SUFFIX, hotfree123.com

# stripchat.com / hplives.com 附属广告域名
DOMAIN-SUFFIX, ststandard.com

# stripchat.com 附属互动设备 API（Lovense）
DOMAIN-SUFFIX, display.lovense-api.com


# ── 百度地图 ──────────────────

# 百度移动广告服务（Mobile Ads），开屏广告主要来源之一
DOMAIN, mobads.baidu.com

# 百度移动广告分发服务（Mobile Baidu Distribution），开屏广告主要来源之一
DOMAIN, mbd.baidu.com

# 百度积分墙广告服务
DOMAIN, integralwall.baidu.com

# 百度广告/游戏推广相关，与地图核心功能无关
DOMAIN, bgg.baidu.com

# 百度推送营销 API，用于广告/营销消息推送
DOMAIN, api.tuisong.baidu.com

# Feed 流内容桶 CDN，用于信息流推荐/广告内容分发
DOMAIN, se-feed-bucket.cdn.bcebos.com

# DMP 静态资源（Data Management Platform），用于用户画像与广告定向
DOMAIN, dmpstatic.cdn.bcebos.com

# 百度信息流/新闻资讯静态资源，与地图导航无关
DOMAIN, now.bdstatic.com

# 百度地图活动/运营页面资源 CDN，通常用于加载广告活动图
DOMAIN, pms-cdn.bdstatic.com

# 百度 App Link Service，应用链接追踪服务，与导航功能无关
DOMAIN, als.baidu.com

# 百度 IP 定位辅助服务，上传 IP 和设备信息用于粗略定位，属定位追踪类，对 GPS 定位影响极小
DOMAIN, bz-ipdx.baidu.com

# 百度 H2T 工具箱服务，功能不明确，与导航无直接关系
DOMAIN, h2tcbox.baidu.com

# 百度地图内置打车聚合服务，属商业增值模块，会收集位置推送打车信息
DOMAIN, yongche.baidu.com

# 糯米（百度本地生活）API，与导航功能无直接关系
DOMAIN, huiduapi.nuomi.com

# 百度广告相关 IP
IP-CIDR, 180.76.76.200/32, no-resolve


