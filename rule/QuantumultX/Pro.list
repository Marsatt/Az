# ==============================
# 🎰 PolyMarket
# ==============================
## 关联 B.list-------------------
# Alchemy 的 Polygon 主网节点域名，Polymarket 必须访问它
HOST, polygon-mainnet.g.alchemy.com
# Alchemy 的以太坊主网节点域名，Polymarket 必须访问它
HOST, eth-mainnet.g.alchemy.com

## 关联 Amazon_Facebook.list-------------------
# AWS KMS 密钥管理服务（Polymarket 用于加密与签名）
HOST, kms.us-west-2.amazonaws.com
# Polymarket 使用的 AWS S3 文件上传域名，拒绝会导致图片/文件无法加载
HOST, polymarket-upload.s3.us-east-2.amazonaws.com




# 官方主域名（已覆盖 app.polymarket.com）
HOST-SUFFIX, polymarket.com

# Fun.xyz 数据 API（区块链支付 / 充值相关）
HOST-SUFFIX, fun.xyz

# Relay.link 跨链支付 API（充值、桥接用）
HOST-SUFFIX, relay.link

# Sportradar 体育数据小部件（比分、比赛数据）
HOST, widgets.sir.sportradar.com

# 常用镜像 / 备用域名
HOST-SUFFIX, platform.grcv.io
HOST-SUFFIX, polymarket.xyz
HOST-SUFFIX, polymarket.sh
HOST-SUFFIX, polymk.com
HOST-SUFFIX, pmarket.io
HOST-SUFFIX, polymkt.net
HOST-SUFFIX, poly.market
HOST-SUFFIX, magic.link
HOST, tee.express.magiclabs.com

# Cloudflare Pages 镜像
HOST-SUFFIX, polymarket.pages.dev

# Meshor 边缘服务
HOST-SUFFIX, meshor.info

# MoonPay（充值通道）- 建议走代理
HOST-SUFFIX, moonpay.com
HOST-SUFFIX, moonpayassets.com

# Sportradar 是全球最大的体育数据供应商之一，为媒体、比分 App、博彩公司、预测市场等提供实时比赛数据和统计。
HOST-SUFFIX, sportradar.com
